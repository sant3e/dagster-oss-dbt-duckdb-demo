# Copy to .env and adjust if needed. docker-compose reads .env automatically.

# Dagster home inside containers (don't change unless you also change the volume mounts)
DAGSTER_HOME=/opt/dagster/dagster_home

# Shared DuckDB warehouse path inside containers
DUCKDB_PATH=/warehouse/oss_template.duckdb

# Where landing CSVs appear inside containers
DATA_LANDING_DIR=/data/landing

# dbt project dir inside containers
DBT_PROJECT_DIR=/opt/dbt_project
DBT_PROFILES_DIR=/opt/dbt_project
